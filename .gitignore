# =========================
# Python
# =========================
__pycache__/
.pycache_tmp/
*.pyc
*.pyc.*
*.pyo
*.pyd

# =========================
# Local history / editor cache
# =========================
.history/
.lh/
.vscode/
.idea/
.DS_Store
Thumbs.db

# =========================
# Coverage / test artifacts
# =========================
coverage/
.coverage
htmlcov/

# =========================
# Runtime temp outputs
# =========================
temp/
downloads/
favorites/
*.tmp
*.bak
*.swp

# Office temporary lock files
~$*.docx
~$*.xlsx
~$*.pptx
docs/~$*

# =========================
# data runtime artifacts
# 这些目录在 GitHub 版中只保留空目录结构
# =========================
data/runtime/*
!data/runtime/.gitkeep

data/workspace/*
!data/workspace/.gitkeep

data/logs/*
!data/logs/.gitkeep

data/histories/*
!data/histories/.gitkeep

# =========================
# Local machine-specific configs
# 真实本机配置不要上传，只上传 template
# =========================
data/user_prefs/*
!data/user_prefs/.gitkeep
!data/user_prefs/*.example.json
!data/user_prefs/*.template.json
agent_config.json
!agent_config.example.json

# =========================
# Secrets
# =========================
token*.txt
*.token
*.secret
*.key

# =========================
# Large local model weights / assets
# 不上传 GPT-SoVITS 权重和大音频资源
# =========================
models/tts/**
models/tts/gpt_sovits/**/*.ckpt
models/tts/gpt_sovits/**/*.pth
models/tts/gpt_sovits/**/*.pt
models/tts/gpt_sovits/**/*.bin
models/tts/gpt_sovits/**/*.wav
models/tts/gpt_sovits/**/*.WAV
models/tts/gpt_sovits/**/*.mp3
models/tts/gpt_sovits/**/*.flac
models/tts/gpt_sovits/**/*.txt

# Local voice reference audio can be large or private.
library/voices/*/
!library/voices/1/
!library/voices/1/**
!library/voices/soft_voice/
!library/voices/soft_voice/**
library/voices/**/ref.wav
library/voices/**/ref.WAV
library/voices/**/ref.mp3
library/voices/**/ref.flac
library/voices/**/ref.txt
library/voices/**/gpt_sovits.json

# Local style/combo drafts used during manual testing.
library/styles/测试*/
library/presets/combos/测试*.json

# Runtime learning/memory generated by desktop command systems.
services/desktop/**/command_memory_library/*.local.json
services/desktop/**/command_memory_library/*.runtime.json
services/desktop/**/command_memory_library/learned_candidates.json
services/desktop/**/command_memory_library/user_habits*.json

# =========================
# Optional local generated files
# =========================
*.log
